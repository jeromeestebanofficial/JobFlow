# App
APP_NAME=JobFlow
DEBUG=false
SECRET_KEY=change-this-to-a-long-random-string-in-production

# Database (SQLite default, swap to postgres in prod)
DATABASE_URL=sqlite:///./jobflow.db

# JWT
JWT_SECRET=change-this-jwt-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis (optional — falls back to in-memory cache if not set)
# REDIS_URL=redis://localhost:6379

# Encryption key for stored API keys (32-byte base64 string)
ENCRYPTION_KEY=

# Rate limiting
MAX_APPLICATIONS_PER_DAY=40
MIN_DELAY_SECONDS=2.0
MAX_DELAY_SECONDS=7.0

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# RapidAPI LinkedIn jobs
# RAPIDAPI_KEY=your-rapidapi-key
# RAPIDAPI_HOST=linkedin-job-search-api.p.rapidapi.com
# RAPIDAPI_LINKEDIN_PATH=/active-jb-24h

# Grant admin UI/API access (comma-separated emails; matched case-insensitively on startup)
# ADMIN_EMAILS=you@example.com
